{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "rwpSchemaVersion": "0.0.1",
  "schemaId": "did:rwp:parlament.ch/schema/fragestunde-frage",
  "displayName": "Fragestunde — Frage",
  "description": "Eine parlamentarische Frage an den Bundesrat im Rahmen der Fragestunde.",
  "allowedStates": ["draft", "finalized"],
  "stateTransitions": [
    { "from": "draft", "to": "finalized", "requiresOwnerSignature": true }
  ],
  "payloadFormats": {
    "draft": ["application/json"],
    "finalized": ["application/json"]
  },
  "type": "object",
  "required": ["fragetext", "session", "parlamentarier_did", "eingereicht_am"],
  "properties": {
    "fragetext": {
      "type": "string",
      "maxLength": 500,
      "description": "Der Text der Frage (max. 500 Zeichen)."
    },
    "session": {
      "type": "string",
      "description": "Session-Bezeichnung, z. B. 'Herbstsession 2026'."
    },
    "parlamentarier_did": {
      "type": "string",
      "pattern": "^did:rwp:",
      "description": "DID des einreichenden Parlamentariers."
    },
    "eingereicht_am": {
      "type": "string",
      "format": "date-time",
      "description": "Zeitpunkt der Einreichung (ISO 8601)."
    },
    "departement_ziel": {
      "type": "string",
      "description": "Optionale Angabe des adressierten Departements.",
      "enum": ["EDA", "EDI", "EJPD", "VBS", "EFD", "WBF", "UVEK", "BK"]
    }
  },
  "additionalProperties": false
}